process {
    withName: CONVERT_XENIUM {
        cpus             = 8
        memory           = '128 GB'
        time             = '30m'
    }
    withName: RESEGMENT_NUCLEI {
        cpus             = 8
        memory           = '256 GB'
        time             = '48h'
        queue            = 'gpu_a100_22c'
        clusterOptions   = '--gpus a100:1'
        containerOptions = '--nv'
    }
    withName: RESEGMENT_CELLS {
        cpus             = 16
        memory           = '512 GB'
        time             = '48h'
    }
    withName: DETECT_TISSUE {
        cpus             = 8
        memory           = '32 GB'
        time             = '10m'
    }
    withName: SPLIT_SAMPLES {
        cpus             = 8
        memory           = '128 GB'
        time             = '60m'
    }
    withName: IDENTIFY_PROGRAMS {
        cpus             = 16
        memory           = '32 GB'
        time             = '6 h'
    }
}